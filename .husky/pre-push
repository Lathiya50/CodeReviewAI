echo "Running lint check..."

pnpm run lint

if [ $? -ne 0 ]; then
  echo "Lint failed! Push aborted."
  exit 1
fi

echo "Lint passed. Running type check..."

pnpm exec tsc --noEmit

if [ $? -ne 0 ]; then
  echo "Type check failed! Push aborted."
  exit 1
fi

echo "Lint and type check succeeded. Proceeding with push."
